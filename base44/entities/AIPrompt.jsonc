{
  "name": "AIPrompt",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "v1.0"
    },
    "purpose": {
      "type": "string"
    },
    "promptText": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "promptText"
  ]
}